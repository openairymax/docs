{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agentos.org/schemas/skill_contract.json",
  "title": "Skill Contract Schema (AgentOS/)",
  "description": "AgentOS Skill 契约 JSON Schema 规范，基于五维正交设计体系（系统观、内核观、认知观、工程观、设计美学），用于验证技能能力描述文件。理论基础：工程两论、双系统认知、微核心哲学、设计美学。",
  "type": "object",
  "required": [
    "schema_version",
    "skill_id",
    "skill_name",
    "version",
    "description",
    "type",
    "required_permissions",
    "cost_profile",
    "trust_metrics"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "契约规范的版本号",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "skill_id": {
      "type": "string",
      "description": "技能唯一标识，建议使用反向域名或 UUID",
      "pattern": "^[a-zA-Z0-9._-]+$"
    },
    "skill_name": {
      "type": "string",
      "description": "技能可读名�?
    },
    "version": {
      "type": "string",
      "description": "技能自身版本号（语义化版本�?,
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
    },
    "description": {
      "type": "string",
      "description": "技能的简要描�?
    },
    "type": {
      "type": "string",
      "description": "技能类�?,
      "enum": ["tool", "code", "api", "file", "browser", "db", "shell"]
    },
    "executable": {
      "type": "object",
      "description": "可执行文件信息（对于编译型技能）",
      "properties": {
        "path": { "type": "string" },
        "entry": { "type": "string" }
      },
      "additionalProperties": false
    },
    "tools": {
      "type": "array",
      "description": "技能提供的工具列表",
      "items": {
        "type": "object",
        "required": ["name", "description", "input_schema", "output_schema"],
        "properties": {
          "name": {
            "type": "string",
            "description": "工具名称"
          },
          "description": {
            "type": "string",
            "description": "工具描述"
          },
          "input_schema": {
            "$ref": "#/definitions/json_schema",
            "description": "输入数据�?JSON Schema"
          },
          "output_schema": {
            "$ref": "#/definitions/json_schema",
            "description": "输出数据�?JSON Schema"
          },
          "estimated_tokens": {
            "type": "integer",
            "minimum": 0,
            "description": "单次调用预估 Token 数（平均值）"
          },
          "avg_duration_ms": {
            "type": "integer",
            "minimum": 0,
            "description": "平均执行时间（毫秒）"
          },
          "success_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "历史成功率（0-1�?
          }
        },
        "additionalProperties": false
      }
    },
    "dependencies": {
      "type": "object",
      "description": "依赖声明",
      "properties": {
        "libraries": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "packages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["language", "name"],
            "properties": {
              "language": { "type": "string" },
              "name": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "commands": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "skills": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "required_permissions": {
      "type": "array",
      "description": "所需权限列表",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "cost_profile": {
      "type": "object",
      "required": ["token_per_task_avg", "api_cost_per_task", "maintenance_level"],
      "properties": {
        "token_per_task_avg": {
          "type": "integer",
          "minimum": 0,
          "description": "单次任务平均 Token 消�?
        },
        "api_cost_per_task": {
          "type": "number",
          "minimum": 0,
          "description": "单次任务平均 API 成本（美元）"
        },
        "maintenance_level": {
          "type": "string",
          "enum": ["community", "verified", "official"],
          "description": "维护级别"
        }
      },
      "additionalProperties": false
    },
    "trust_metrics": {
      "type": "object",
      "required": ["install_count", "rating", "verified_provider", "last_audit"],
      "properties": {
        "install_count": {
          "type": "integer",
          "minimum": 0,
          "description": "安装次数"
        },
        "rating": {
          "type": "number",
          "minimum": 0,
          "maximum": 5,
          "description": "用户评分�?-5�?
        },
        "verified_provider": {
          "type": "boolean",
          "description": "是否经过官方认证"
        },
        "last_audit": {
          "type": "string",
          "format": "date",
          "description": "上次审计日期（ISO 8601�?
        }
      },
      "additionalProperties": false
    },
    "extensions": {
      "type": "object",
      "description": "扩展字段，用于社区自定义",
      "additionalProperties": true
    }
  },
  "definitions": {
    "json_schema": {
      "description": "JSON Schema 对象（符�?JSON Schema Draft-07�?,
      "type": "object",
      "properties": {
        "$ref": { "type": "string", "format": "uri" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
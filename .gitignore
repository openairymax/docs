# ===========================================================================
# Airymax Docs 叶子仓 — .gitignore
# 策略：非必要不追踪，全面保护本地开发路径
# ===========================================================================

# ===========================================================================
# IDE 配置
# ===========================================================================
.vscode/
.idea/
.trae/
.lingma/
.vs/
*.code-workspace
*.code-snippets
*.sublime-project
*.sublime-workspace
.clangd/
.cache/clangd/
.project
.classpath
.settings/
*.swp
*.swo
*~
\#*\#
.\#*

# ===========================================================================
# 操作系统文件
# ===========================================================================
.DS_Store
.AppleDouble
.LSOverride
._*
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icn
.apdisk
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ===========================================================================
# 临时文件和备份
# ===========================================================================
*.tmp
*.temp
*.bak
*.backup
*.orig
tmp/
temp/
*.draft
*.notes
*.todo
*.personal
*.private
*.local
DRAFT*
NOTES*
TODO*

# ===========================================================================
# 日志文件
# ===========================================================================
*.log
logs/

# ===========================================================================
# 环境文件（敏感信息）
# ===========================================================================
.env
.env.*
!.env.example
*.key
*.pem
*.cert
secrets.json
secrets.yaml

# ===========================================================================
# 构建产物
# ===========================================================================
build/
_build/
cmake-build-*/
out/
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dll
*.dylib
*.exe
*.out
*.app
*.d
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json

# ===========================================================================
# Python
# ===========================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg-info/
*.egg
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
venv/
.venv/

# ===========================================================================
# Rust / Go / Node
# ===========================================================================
target/
Cargo.lock
*.test
*.out
vendor/
node_modules/
*.tsbuildinfo

# ===========================================================================
# 数据库
# ===========================================================================
*.db
*.sqlite
*.sqlite3
*.db-journal

# ===========================================================================
# 大文件资源（不入库，由发布流程注入）
# ===========================================================================
Source_Other/*.gif
Source_Other/*.png
Source_Other/*.jpg
Source_Other/*.jpeg
Source_Other/*.mp4
Source_Other/*.webm

# ===========================================================================
# 测试结果
# ===========================================================================
test-results/
*.gcov
*.gcda
*.gcno
coverage/

# ===========================================================================
# Sphinx 文档生成
# ===========================================================================
_build/
doctrees/

# =============================================================================

# -----------------------------------------------------------------------------
# IDE 配置
# -----------------------------------------------------------------------------
.trae/
.vscode/
.idea/
.vs/
*.code-workspace
*.code-snippets
.clangd/
.cache/clangd/

# -----------------------------------------------------------------------------
# 构建产物
# -----------------------------------------------------------------------------
build/
_build/
cmake-build-*/
out/
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dll
*.dylib
*.exe
*.out
*.app
*.d

# -----------------------------------------------------------------------------
# CMake
# -----------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json
compile_flags.txt

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.egg
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
venv/
.venv/

# -----------------------------------------------------------------------------
# Rust
# -----------------------------------------------------------------------------
target/
Cargo.lock

# -----------------------------------------------------------------------------
# Go
# -----------------------------------------------------------------------------
*.test
*.out
cover.out
cover.html
vendor/

# -----------------------------------------------------------------------------
# Node
# -----------------------------------------------------------------------------
node_modules/
dist/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# 系统文件
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.lnk
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# 编辑器临时
# -----------------------------------------------------------------------------
*.swp
*.swo
*~
\#*\#
.\#*

# -----------------------------------------------------------------------------
# 日志临时
# -----------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.temp
tmp/
temp/

# -----------------------------------------------------------------------------
# 本地环境
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets.json
secrets.yaml

# -----------------------------------------------------------------------------
# 数据库
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# 测试覆盖率
# -----------------------------------------------------------------------------
test-results/
*.gcov
*.gcda
*.gcno
coverage/

# -----------------------------------------------------------------------------
# 本地草稿
# -----------------------------------------------------------------------------
*.draft
*.todo
*.notes
*.personal
*.private
*.local

# -----------------------------------------------------------------------------
# 大文件资源（不入库，由发布流程注入）
# -----------------------------------------------------------------------------
Source_Other/*.gif
Source_Other/*.png
Source_Other/*.jpg
Source_Other/*.jpeg
Source_Other/*.mp4
Source_Other/*.webm

# -----------------------------------------------------------------------------
# 例外保留
# -----------------------------------------------------------------------------
!.env.example
!.editorconfig
!.gitattributes
!.gitignore
!.dockerignore
